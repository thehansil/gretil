{
  "name": "gretil",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext .ts",
    "start": "tsc && node ./dist/index.js",
    "debug": "npx tsx watch ./src/index.ts",
    "prod": "tsc && dotenvx run -f .env.production -- node ./dist/index.js",
    "register-prod-commands": "dotenvx run -f .env.production -- tsx src/register-commands.ts",
    "register-commands": "tsx src/register-commands.ts",
    "docker-build": "docker build --platform linux/amd64 -t hansil/gretil .",
    "docker-push": "docker push hansil/gretil:latest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.24.0",
    "chrono-node": "^2.9.0",
    "discord.js": "^14.9.0",
    "mongoose": "^8.13.2",
    "node-cron": "^4.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.20.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1"
  },
  "allowScripts": {
    "esbuild@0.25.0": true,
    "fsevents@2.3.3": true
  }
